-- کاتیگۆریەکان
create table categories (
  id uuid primary key default gen_random_uuid(),
  name text not null unique,
  created_at timestamptz default now()
);

-- کاڵاکان
create table products (
  id uuid primary key default gen_random_uuid(),
  name text not null,
  brand text,
  model text,
  category text not null,
  buy_price numeric default 0,
  sell_price numeric not null,
  qty integer default 0,
  notes text,
  barcode text,
  image_url text,
  created_at timestamptz default now()
);

-- فرۆشتنەکان
create table sales (
  id uuid primary key default gen_random_uuid(),
  product_id uuid,
  product_name text,
  product_model text,
  unit_price numeric default 0,
  qty integer default 1,
  total numeric default 0,
  profit numeric default 0,
  returned boolean default false,
  returned_at timestamptz,
  created_at timestamptz default now()
);

-- چاکسازییەکان
create table repairs (
  id uuid primary key default gen_random_uuid(),
  customer_name text not null,
  phone text,
  device text,
  device_type text,
  problem text,
  cost numeric default 0,
  status text default 'received',
  notes text,
  image_url text,
  created_at timestamptz default now()
);

-- قەرزەکان
create table debts (
  id uuid primary key default gen_random_uuid(),
  customer_name text not null,
  phone text,
  amount numeric default 0,
  paid_amount numeric default 0,
  source text,
  notes text,
  due_date date,
  status text default 'pending',
  created_at timestamptz default now()
);

-- پلانەکان
create table plans (
  id uuid primary key default gen_random_uuid(),
  title text not null,
  content text,
  status text default 'active',
  created_at timestamptz default now()
);

-- خەرجییەکان
create table expenses (
  id uuid primary key default gen_random_uuid(),
  title text not null,
  amount numeric default 0,
  category text,
  note text,
  created_at timestamptz default now()
);

-- ڕێکخستنەکان (تەنها یەک ڕیز)
create table settings (
  id integer primary key,
  store_name text default 'Mobile Store',
  store_phone text,
  store_address text,
  primary_color text default '#6C63FF',
  secondary_color text default '#00D9A6',
  theme_mode text default 'dark',
  app_pin text default '1887',
  reset_pin text default '1991',
  font_size text default 'medium',
  density text default 'normal',
  bg_pattern text default 'default',
  bg_color text default '#080d1a',
  image_size integer default 40,
  currency text default 'iqd',
  auto_print boolean default false
);

