-- 1. کەتەگۆری
create table categories (
  id bigint generated always as identity primary key,
  cat_id text unique not null,
  img text,
  icon text,
  label_ckb text not null,
  label_ar text,
  label_en text,
  sort int default 0,
  created_at timestamptz default now()
);

-- 2. خواردن
create table meals (
  id bigint generated always as identity primary key,
  cat_id text,
  img text,
  price numeric default 0,
  cal numeric default 0,
  prep numeric default 0,
  name_ckb text not null,
  name_ar text,
  name_en text,
  desc_ckb text,
  desc_ar text,
  desc_en text,
  sort int default 0,
  created_at timestamptz default now()
);

-- 3. پەیوەندی خواردن بە چەند کەتەگۆرییەوە
create table meal_categories (
  meal_id bigint references meals(id) on delete cascade,
  cat_id text,
  primary key (meal_id, cat_id)
);

-- 4. ڕێکخستنەکانی سایت (تەنها ڕیزێک، id=1)
